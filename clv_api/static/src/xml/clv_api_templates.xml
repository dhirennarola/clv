<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">

    <t t-name="clv_api.ScannerOverlay" owl="1">
        <div class="clv-api-scanner-overlay">
            <div class="clv-api-scanner-viewport">
                <div class="clv-api-scanner-prompt">
                    <t t-esc="props.prompt"/>
                </div>
                <div class="clv-api-scanner-hint">
                    <t t-esc="props.hint"/>
                </div>
                <input type="text"
                       class="clv-api-scanner-input"
                       t-att-placeholder="props.placeholder"
                       t-on-keydown="props.onKeyDown"
                       autofocus="1"/>
            </div>
        </div>
    </t>

    <t t-name="clv_api.StockPickCard" owl="1">
        <div class="clv-api-stock-pick-card">
            <header>
                <span class="clv-api-pick-card-title">
                    <t t-esc="props.title"/>
                </span>
                <span class="clv-api-pick-card-state" t-att-data-state="props.state">
                    <t t-esc="props.state"/>
                </span>
            </header>
            <div class="clv-api-pick-card-body">
                <div class="clv-api-pick-card-product">
                    <t t-esc="props.product"/>
                </div>
                <div class="clv-api-pick-card-location">
                    <t t-esc="props.location"/>
                </div>
                <div class="clv-api-pick-card-qty">
                    <t t-esc="props.qtyDone"/> / <t t-esc="props.qtyPlanned"/>
                </div>
            </div>
            <footer class="clv-api-pick-progress">
                <div class="clv-api-pick-progress-bar">
                    <div class="clv-api-pick-progress-fill"
                         t-attf-style="width: {{ props.progressPct }}%"/>
                </div>
                <span><t t-esc="props.progressPct"/>%</span>
            </footer>
        </div>
    </t>

    <t t-name="clv_api.LotBadge" owl="1">
        <span class="clv-api-lot-badge"
              t-att-class="{
                  'is-expiring': props.expiry === 'soon',
                  'is-expired': props.expiry === 'past',
              }">
            <t t-esc="props.lot"/>
            <small t-if="props.formattedExpiry">
                · <t t-esc="props.formattedExpiry"/>
            </small>
        </span>
    </t>

    <t t-name="clv_api.WizardStepHeader" owl="1">
        <header class="clv-api-wizard-step-header">
            <span class="clv-api-step-number">
                Step <t t-esc="props.index"/> / <t t-esc="props.total"/>
            </span>
            <h2 class="clv-api-step-title">
                <t t-esc="props.title"/>
            </h2>
            <p class="clv-api-step-subtitle" t-if="props.subtitle">
                <t t-esc="props.subtitle"/>
            </p>
        </header>
    </t>

</templates>
